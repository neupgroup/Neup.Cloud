generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationServerMapStatus {
  stopped
  started
  inactive
}

model Server {
  id                    String                 @id @db.Text
  name                  String                 @db.Text
  username              String                 @db.Text
  type                  String                 @db.Text
  provider              String                 @db.Text
  moreDetails           String?                @map("moreDetails") @db.Text
  publicIp              String                 @map("publicIp") @db.Text
  privateIp             String?                @map("privateIp") @db.Text
  privateKey            String?                @map("privateKey") @db.Text
  publicKey             String?                @map("publicKey") @db.Text
  proxyHandler          String?                @map("proxyHandler") @db.Text
  loadBalancer          String?                @map("loadBalancer") @db.Text
  createdAt             DateTime               @map("createdAt") @db.Timestamp(6)
  updatedAt             DateTime               @map("updatedAt") @db.Timestamp(6)
  applicationServerMaps ApplicationServerMap[]

  @@map("servers")
}

model ServerLog {
  id          String   @id @db.Text
  serverId    String   @map("serverId") @db.Text
  command     String   @db.Text
  commandName String?  @map("commandName") @db.Text
  output      String?  @db.Text
  status      String   @db.Text
  runAt       DateTime @map("runAt") @db.Timestamp(6)
  source      String?  @db.Text
  accountId   String?  @map("accountId") @db.Text

  @@map("server_logs")
}

model SavedCommand {
  id           String   @id @db.Text
  name         String   @db.Text
  command      String   @db.Text
  description  String?  @db.Text
  nextCommands String[] @default([])
  variables    Json?
  createdAt    DateTime @map("createdAt") @db.Timestamp(6)
  updatedAt    DateTime @map("updatedAt") @db.Timestamp(6)

  @@map("saved_commands")
}

model Application {
  id            String                 @id @db.Text
  name          String                 @db.Text
  appIcon       String?                @map("appIcon") @db.Text
  location      String                 @db.Text
  language      String                 @db.Text
  repository    String?                @db.Text
  networkAccess String[]               @default([])
  commands      Json?
  information   Json?
  owner         String                 @db.Text
  createdAt     DateTime               @map("createdAt") @db.Timestamp(6)
  updatedAt     DateTime               @map("updatedAt") @db.Timestamp(6)
  environments  Json?
  files         Json?
  serverMaps    ApplicationServerMap[]

  @@map("applications")
}

model ApplicationServerMap {
  id            String                     @id @db.Text
  serverId      String                     @map("server_id") @db.Text
  applicationId String                     @map("application_id") @db.Text
  status        ApplicationServerMapStatus @default(started)
  isPrimary     Boolean                    @default(false) @map("is_primary")

  server      Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, serverId], map: "application_server_map_app_server_unique")
  @@index([applicationId], map: "application_server_map_application_id_idx")
  @@index([serverId], map: "application_server_map_server_id_idx")
  @@map("application_server_map")
}

model Domain {
  id               String   @id @db.Text
  name             String   @unique @db.Text
  status           String   @db.Text
  addedAt          DateTime @map("addedAt") @db.Timestamp(6)
  verificationCode String?  @map("verificationCode") @db.Text
  verified         Boolean

  @@map("domains")
}

model EnvironmentVariable {
  id              String   @id @db.Text
  key             String   @db.Text
  value           String   @db.Text
  targetType      String   @map("targetType") @db.Text
  selectedTargets String[] @default([]) @map("selectedTargets")
  isConfidential  Boolean  @map("isConfidential")
  protectValue    Boolean  @map("protectValue")
  createdAt       DateTime @map("createdAt") @db.Timestamp(6)

  @@map("environment_variables")
}

model AppError {
  id        String   @id @db.Text
  message   String   @db.Text
  level     String   @db.Text
  source    String   @db.Text
  timestamp DateTime @db.Timestamp(6)
  stack     String?  @db.Text

  @@map("errors")
}

model LiveSession {
  id          String   @id @db.Text
  createdAt   DateTime @map("createdAt") @db.Timestamp(6)
  cwd         String   @db.Text
  status      String   @db.Text
  history     Json
  serverLogId String?  @map("serverLogId") @db.Text
  serverId    String?  @map("serverId") @db.Text

  @@map("live_sessions")
}

model AccessToken {
  id        BigInt @id @default(autoincrement())
  accountId String @map("account_id") @db.Text
  name      String @db.Text
  key       String @map("key") @db.Text

  @@map("accessTokens")
}

model IntelligenceModel {
  id          BigInt  @id @default(autoincrement())
  title       String  @db.Text
  provider    String  @db.Text
  model       String  @db.Text
  description String? @db.Text
  currency    String  @default("USD") @db.Text
  inputPrice  Float   @map("inputPrice")
  outputPrice Float   @map("outputPrice")

  @@unique([provider, model], map: "intelligence_models_provider_model_unique")
  @@map("intelligence_models")
}

model IntelligenceAccess {
  id           String   @id @db.Text
  accountId    String   @map("account_id") @db.Text
  keyHash      String   @unique @map("key_hash") @db.Text
  type         String   @db.Text
  availableTo  Json     @map("available_to")
  details      Json     @default("[]")
  maxTokens    Int?     @map("max_tokens")
  tokenBalance Float    @default(0) @map("token_balance")
  status       String   @default("unpublished") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  logs IntelligenceLog[]

  @@index([accountId], map: "intelligence_access_account_id_idx")
  @@index([keyHash], map: "intelligence_access_key_hash_idx")
  @@map("intelligence_access")
}

model IntelligenceLog {
  id         BigInt   @id @default(autoincrement())
  accessId   String   @map("access_id") @db.Text
  details    Json
  from       String?  @db.Text
  type       String   @default("discharge") @db.Text
  balance    Float?
  devDetails Json?    @map("dev_details")
  loggedOn   DateTime @default(now()) @map("logged_on") @db.Timestamp(6)

  access IntelligenceAccess @relation(fields: [accessId], references: [id], onDelete: Cascade)

  @@index([accessId], map: "intelligence_log_access_id_idx")
  @@index([type], map: "intelligence_log_type_idx")
  @@map("intelligence_log")
}

model OpenFlowUsageLog {
  id         BigInt   @id @default(autoincrement())
  accountId  String   @map("account_id") @db.Text
  tokenLast4 String   @map("token_last4") @db.Text
  modelUsed  String   @map("model_used") @db.Text
  provider   String   @db.Text
  usedAt     DateTime @default(now()) @map("used_at") @db.Timestamp(6)

  @@index([accountId], map: "openflow_usage_log_account_id_idx")
  @@index([usedAt], map: "openflow_usage_log_used_at_idx")
  @@map("openflow_usage_log")
}

model Pipeline {
  id          String  @id @db.Text
  accountId   String  @map("account_id") @db.Text
  title       String  @db.Text
  description String? @db.Text
  flowJson    Json    @map("flow_json")

  @@index([accountId], map: "pipelines_account_id_idx")
  @@map("pipelines")
}

model PipelineLog {
  id         String   @id @db.Text
  pipelineId String   @map("pipeline_id") @db.Text
  timestamp  DateTime @db.Timestamp(6)
  logBy      String   @map("log_by") @db.Text
  details    String   @db.Text

  @@index([pipelineId, timestamp], map: "pipeline_logs_pipeline_id_timestamp_idx")
  @@map("pipeline_logs")
}

model Database {
  id               String    @id @db.Text
  title            String    @db.Text
  description      String    @db.Text
  connectionType   String    @map("connectionType") @db.Text
  connectionStatus String    @default("connected") @map("connectionStatus") @db.Text
  credentails      String    @db.Text
  authConfig       Json
  lastValidatedAt  DateTime? @map("lastValidatedAt") @db.Timestamp(6)
  createdAt        DateTime  @default(now()) @map("createdAt") @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("databases")
}

model Account {
  id String @id @db.Text

  permits Permit[]

  @@map("accounts")
}

model Permit {
  id          String  @id @db.Text
  accountId   String  @map("account_id") @db.Text
  portfolioId String? @map("portfolio_id") @db.Text
  assetType   String  @map("asset_type") @db.Text
  assetId     String  @map("asset_id") @db.Text
  role        String  @db.Text

  account Account @relation(fields: [accountId], references: [id])

  @@map("permit")
}

model AuthzRole {
  id          String  @id @default(uuid()) @db.Text
  name        String  @db.Text
  description String? @db.Text
  scope       String? @db.Text

  @@map("authz_role")
}

model AuthzCapability {
  id          String  @id @default(uuid()) @db.Text
  name        String  @db.Text
  description String? @db.Text
  scope       String? @db.Text

  @@map("authz_capability")
}

model AuthzRoleCapability {
  id                     String  @id @default(uuid()) @db.Text
  roleId                 String  @map("role_id") @db.Text
  capabilityId           String  @map("capability_id") @db.Text
  scope                  String? @db.Text
  denormalizedCapability Json?   @map("denormalized_capability")
  roleName               String? @map("role_name") @db.Text

  @@map("authz_role_capability")
}

model AuthzAccountAccessGrant {
  id              String  @id @default(uuid()) @db.Text
  ownerAccountId  String  @map("owner_account_id") @db.Text
  targetAccountId String  @map("target_account_id") @db.Text
  roleId          String  @map("role_id") @db.Text
  portfolioId     String? @map("portfolio_id") @db.Text

  @@map("authz_account_access_grant")
}

model AuthzAssetsAccessGrant {
  id          String  @id @default(uuid()) @db.Text
  assetId     String  @map("asset_id") @db.Text
  accountId   String  @map("account_id") @db.Text
  roleId      String  @map("role_id") @db.Text
  portfolioId String? @map("portfolio_id") @db.Text
  assetType   String? @map("asset_type") @db.Text

  @@map("authz_assets_access_grant")
}
